# Copy to .env

# SQLite (simple local dev — file created next to prisma folder when using path below)
DATABASE_URL="file:./dev.db"

# For PostgreSQL instead, set provider in prisma/schema.prisma to postgresql and use e.g.:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/orbit_dev?schema=public"

JWT_SECRET="use-a-long-random-string-at-least-32-characters"
PORT=3000
FRONTEND_URL="http://localhost:5173,http://localhost:5175"
